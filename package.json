{
  "name": "wedding-invitation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/marketing"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "marketing:dev": "npm run dev --workspace @guesto/marketing",
    "marketing:build": "npm run build --workspace @guesto/marketing",
    "marketing:start": "npm run start --workspace @guesto/marketing",
    "marketing:typecheck": "npm run typecheck --workspace @guesto/marketing",
    "capture:desktop": "node scripts/capture-landing.mjs --device desktop",
    "capture:mobile": "node scripts/capture-landing.mjs --device mobile",
    "capture:screenshots": "node scripts/capture-landing.mjs --device desktop --screenshots-only && node scripts/capture-landing.mjs --device mobile --screenshots-only",
    "capture:all": "node scripts/capture-landing.mjs --device desktop && node scripts/capture-landing.mjs --device mobile"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.94.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sass": "^1.97.3",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
